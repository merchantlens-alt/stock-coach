# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=asia-south1

# Vertex AI
VERTEX_AI_MODEL_FLASH=gemini-2.5-flash
VERTEX_AI_MODEL_PRO=gemini-2.5-flash

# News API (free tier at newsapi.org — 100 req/day)
NEWS_API_KEY=your-newsapi-key

# Cache — set REDIS_URL to use Redis, leave empty for in-memory cache (dev only)
REDIS_URL=redis://localhost:6379/0

# Cache TTL (seconds)
GAINERS_LIST_TTL=1800
ANALYSIS_TTL=21600

# API
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Set to true to return mock AI responses (no GCP billing, for local dev)
MOCK_AI=false

# Top N gainers to return per market
TOP_GAINERS_COUNT=20
