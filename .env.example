# ── Google Cloud ───────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=asia-south1

# ── Vertex AI models ───────────────────────────────────────────────────────────
VERTEX_AI_MODEL_FLASH=gemini-2.5-flash
VERTEX_AI_MODEL_PRO=gemini-2.5-flash

# ── News API ───────────────────────────────────────────────────────────────────
# Free tier: https://newsapi.org  (100 req/day)
NEWS_API_KEY=your-newsapi-key

# ── Cache ──────────────────────────────────────────────────────────────────────
# Leave REDIS_URL empty to use the built-in in-memory cache (dev/single-instance).
# Set to redis://localhost:6379/0 (or a Cloud Memorystore URL) for production.
REDIS_URL=

# Cache TTL (seconds)
GAINERS_LIST_TTL=1800   # 30 minutes
ANALYSIS_TTL=21600      # 6 hours

# ── API server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ── Feature flags ──────────────────────────────────────────────────────────────
# Set MOCK_AI=true to skip all Gemini calls and return hardcoded responses.
# Use this for local development when you don't have GCP credentials.
MOCK_AI=true

# Number of top gainers to return per market
TOP_GAINERS_COUNT=20
